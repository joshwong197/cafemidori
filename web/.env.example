# Café Midori — web environment
# WebSocket endpoint where the NanoClaw `cafe` channel listens
NEXT_PUBLIC_CAFE_WS=ws://localhost:3722/cafe

# HTTP endpoint on the NanoClaw `cafe` channel for topic-run posts
CAFE_BRIDGE_URL=http://localhost:3722/topic

# Joshua-only shared secret (MVP auth). Generate a random 32-byte hex.
CAFE_SHARED_SECRET=
